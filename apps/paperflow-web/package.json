{
  "name": "paperflow-spa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "concurrently -n mock,vite -c \"cyan,magenta\" \"npm run mock:api\" \"cross-env VITE_API_BASE=http://localhost:3151 vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "mock:api": "cross-env PORT=3151 node ./mock/server.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "2.8.5",
    "d3": "7.9.0",
    "express": "4.21.2",
    "pdfjs-dist": "4.10.38",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.28.0"
  },
  "devDependencies": {
    "@types/d3": "7.4.3",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react-swc": "3.7.1",
    "concurrently": "9.1.0",
    "cross-env": "7.0.3",
    "typescript": "5.6.3",
    "vite": "5.4.11",
    "vitest": "2.1.9"
  }
}
