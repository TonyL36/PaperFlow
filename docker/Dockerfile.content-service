FROM maven:3.9.9-eclipse-temurin-17 AS build
WORKDIR /workspace
COPY . .
RUN mvn -DskipTests -pl backend/services/content-service -am package

FROM eclipse-temurin:17-jre
WORKDIR /app
COPY --from=build /workspace/backend/services/content-service/target/content-service-*.jar /app/app.jar
EXPOSE 8082
ENTRYPOINT ["java","-jar","/app/app.jar"]
